{
  "$defs": {
    "DirectionPaperNode": {
      "additionalProperties": false,
      "properties": {
        "paper": {
          "$ref": "#/$defs/PaperCandidate"
        },
        "role": {
          "title": "Role",
          "type": "string"
        },
        "why_read": {
          "title": "Why Read",
          "type": "string"
        },
        "quality": {
          "$ref": "#/$defs/QualityAssessment"
        }
      },
      "required": [
        "paper",
        "role",
        "why_read",
        "quality"
      ],
      "title": "DirectionPaperNode",
      "type": "object"
    },
    "LearningMode": {
      "enum": [
        "scan_10_min",
        "minimal_45_min",
        "reproducible_2h",
        "direction_mainline_6h"
      ],
      "title": "LearningMode",
      "type": "string"
    },
    "PaperCandidate": {
      "additionalProperties": false,
      "properties": {
        "title": {
          "title": "Title",
          "type": "string"
        },
        "authors": {
          "items": {
            "type": "string"
          },
          "title": "Authors",
          "type": "array"
        },
        "year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Year"
        },
        "venue": {
          "default": "",
          "title": "Venue",
          "type": "string"
        },
        "source_tool": {
          "default": "manual",
          "title": "Source Tool",
          "type": "string"
        },
        "source_platform": {
          "default": "manual",
          "title": "Source Platform",
          "type": "string"
        },
        "url": {
          "default": "",
          "title": "Url",
          "type": "string"
        },
        "pdf_url": {
          "default": "",
          "title": "Pdf Url",
          "type": "string"
        },
        "doi": {
          "default": "",
          "title": "Doi",
          "type": "string"
        },
        "arxiv_id": {
          "default": "",
          "title": "Arxiv Id",
          "type": "string"
        },
        "abstract": {
          "default": "",
          "title": "Abstract",
          "type": "string"
        },
        "citation_count": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Citation Count"
        },
        "open_access": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Open Access"
        },
        "code_url": {
          "default": "",
          "title": "Code Url",
          "type": "string"
        },
        "data_url": {
          "default": "",
          "title": "Data Url",
          "type": "string"
        },
        "quality_signals": {
          "items": {
            "type": "string"
          },
          "title": "Quality Signals",
          "type": "array"
        },
        "risk_flags": {
          "items": {
            "type": "string"
          },
          "title": "Risk Flags",
          "type": "array"
        },
        "retraction_status": {
          "default": "unknown",
          "enum": [
            "clear",
            "retracted",
            "concern",
            "unknown"
          ],
          "title": "Retraction Status",
          "type": "string"
        },
        "raw_result_ref": {
          "default": "",
          "title": "Raw Result Ref",
          "type": "string"
        }
      },
      "required": [
        "title"
      ],
      "title": "PaperCandidate",
      "type": "object"
    },
    "QualityAssessment": {
      "additionalProperties": false,
      "properties": {
        "venue_tier": {
          "default": "unknown",
          "title": "Venue Tier",
          "type": "string"
        },
        "reading_priority": {
          "$ref": "#/$defs/ReadingPriority",
          "default": "C-reference"
        },
        "risk_flags": {
          "items": {
            "type": "string"
          },
          "title": "Risk Flags",
          "type": "array"
        },
        "strengths": {
          "items": {
            "type": "string"
          },
          "title": "Strengths",
          "type": "array"
        },
        "retraction_status": {
          "default": "unknown",
          "enum": [
            "clear",
            "retracted",
            "concern",
            "unknown"
          ],
          "title": "Retraction Status",
          "type": "string"
        },
        "reproducibility": {
          "$ref": "#/$defs/ReproducibilitySignal"
        },
        "manual_check_needed": {
          "items": {
            "type": "string"
          },
          "title": "Manual Check Needed",
          "type": "array"
        },
        "rationale": {
          "default": "",
          "title": "Rationale",
          "type": "string"
        }
      },
      "title": "QualityAssessment",
      "type": "object"
    },
    "ReadingPriority": {
      "enum": [
        "A-read",
        "B-skim",
        "C-reference",
        "Risk-review"
      ],
      "title": "ReadingPriority",
      "type": "string"
    },
    "ReproducibilitySignal": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "default": "unknown",
          "enum": [
            "available",
            "unavailable",
            "unknown"
          ],
          "title": "Code",
          "type": "string"
        },
        "data": {
          "default": "unknown",
          "enum": [
            "available",
            "unavailable",
            "unknown"
          ],
          "title": "Data",
          "type": "string"
        },
        "ablation_quality": {
          "default": "unknown",
          "enum": [
            "strong",
            "weak",
            "missing",
            "unknown"
          ],
          "title": "Ablation Quality",
          "type": "string"
        }
      },
      "title": "ReproducibilitySignal",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "topic": {
      "title": "Topic",
      "type": "string"
    },
    "reading_budget": {
      "title": "Reading Budget",
      "type": "string"
    },
    "mode": {
      "$ref": "#/$defs/LearningMode"
    },
    "core_papers": {
      "items": {
        "$ref": "#/$defs/DirectionPaperNode"
      },
      "title": "Core Papers",
      "type": "array"
    },
    "optional_papers": {
      "items": {
        "$ref": "#/$defs/DirectionPaperNode"
      },
      "title": "Optional Papers",
      "type": "array"
    },
    "paper_roles": {
      "items": {
        "$ref": "#/$defs/DirectionPaperNode"
      },
      "title": "Paper Roles",
      "type": "array"
    },
    "evolution_chain": {
      "items": {
        "type": "string"
      },
      "title": "Evolution Chain",
      "type": "array"
    },
    "open_questions": {
      "items": {
        "type": "string"
      },
      "title": "Open Questions",
      "type": "array"
    },
    "skip_reason": {
      "items": {
        "type": "string"
      },
      "title": "Skip Reason",
      "type": "array"
    },
    "mermaid_graph": {
      "default": "",
      "title": "Mermaid Graph",
      "type": "string"
    }
  },
  "required": [
    "topic",
    "reading_budget",
    "mode"
  ],
  "title": "DirectionMapData",
  "type": "object"
}
