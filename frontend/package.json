{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": "22.13.x",
    "npm": "11.x"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b",
    "preview": "vite preview",
    "test": "vitest run --exclude \"e2e/**\"",
    "test:watch": "vitest --exclude \"e2e/**\"",
    "test:e2e": "playwright test --grep-invert @live",
    "test:e2e:live": "playwright test --grep @live"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "d3": "^7.9.0",
    "katex": "^0.17.0",
    "markdown-it": "^14.3.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.2.8"
  }
}
