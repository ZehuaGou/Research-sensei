RESEARCHSENSEI_ENABLE_API_LLM=1
RESEARCHSENSEI_LLM_PROVIDER=cc_switch

# Cici Switch runs locally at http://127.0.0.1:15721/v1.
# Switch the active model inside Cici Switch; ResearchSensei follows it.

UNPAYWALL_EMAIL=you@example.com
RESEARCHSENSEI_CONTACT_EMAIL=you@example.com
SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-key-here
S2_API_KEY=your-semantic-scholar-key-here

# Optional non-default providers remain documented in config/sensei.example.toml.
DEEPSEEK_API_KEY=your-deepseek-api-key-here
OPENAI_COMPATIBLE_API_KEY=your-openai-compatible-api-key-here
